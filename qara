<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nur Arisa Zuyyin | Portfolio</title>

    <!-- Font Awesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
            font-family:'Poppins',sans-serif;
        }

        body{
            background:#fffafc;
            color:#333;
            scroll-behavior:smooth;
        }

        /* Navigation */
        nav{
            position:fixed;
            top:0;
            width:100%;
            background:white;
            display:flex;
            justify-content:space-between;
            align-items:center;
            padding:15px 8%;
            box-shadow:0 2px 15px rgba(0,0,0,0.08);
            z-index:1000;
        }

        .logo{
            font-size:24px;
            font-weight:700;
            color:#ff69b4;
        }

        nav ul{
            display:flex;
            list-style:none;
            gap:25px;
        }

        nav ul li a{
            text-decoration:none;
            color:#444;
            font-weight:500;
            transition:0.3s;
        }

        nav ul li a:hover{
            color:#ff69b4;
        }

        /* Hero Section */
        .hero{
            min-height:100vh;
            display:flex;
            align-items:center;
            justify-content:center;
            padding:100px 8% 50px;
            background:linear-gradient(135deg,#ffe4ef,#ffffff);
            flex-wrap:wrap;
            gap:50px;
        }

        .hero-text{
            flex:1;
            min-width:300px;
        }

        .hero-text h1{
            font-size:52px;
            color:#ff69b4;
            margin-bottom:10px;
        }

        .hero-text h2{
            font-size:24px;
            color:#666;
            margin-bottom:20px;
        }

        .hero-text p{
            color:#555;
            line-height:1.8;
            margin-bottom:25px;
        }

        .btn{
            display:inline-block;
            padding:12px 28px;
            background:#ff69b4;
            color:white;
            border-radius:30px;
            text-decoration:none;
            transition:0.3s;
        }

        .btn:hover{
            background:#ff4da6;
            transform:translateY(-3px);
        }

        .hero-image{
            flex:1;
            display:flex;
            justify-content:center;
            min-width:300px;
        }

        .profile-placeholder{
            width:300px;
            height:300px;
            border-radius:50%;
            background:white;
            border:8px solid #ffc0db;
            display:flex;
            align-items:center;
            justify-content:center;
            font-size:90px;
            color:#ff69b4;
            box-shadow:0 10px 30px rgba(255,105,180,0.2);
        }

        /* Sections */
        section{
            padding:80px 8%;
        }

        .section-title{
            text-align:center;
            font-size:36px;
            color:#ff69b4;
            margin-bottom:50px;
        }

        /* Cards */
        .cards{
            display:grid;
            grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
            gap:25px;
        }

        .card{
            background:white;
            padding:30px;
            border-radius:20px;
            text-align:center;
            box-shadow:0 5px 20px rgba(0,0,0,0.08);
            transition:0.3s;
        }

        .card:hover{
            transform:translateY(-8px);
        }

        .card i{
            font-size:40px;
            color:#ff69b4;
            margin-bottom:15px;
        }

        .card h3{
            margin-bottom:10px;
        }

        /* Contact */
        .contact-box{
            max-width:700px;
            margin:auto;
            background:white;
            padding:35px;
            border-radius:20px;
            text-align:center;
            box-shadow:0 5px 20px rgba(0,0,0,0.08);
        }

        .contact-box i{
            color:#ff69b4;
            margin-right:10px;
        }

        footer{
            text-align:center;
            padding:20px;
            background:#ffe4ef;
            color:#555;
        }

        @media(max-width:768px){
            .hero-text h1{
                font-size:40px;
            }

            nav{
                flex-direction:column;
                gap:10px;
            }

            nav ul{
                flex-wrap:wrap;
                justify-content:center;
            }
        }
    </style>
</head>
<body>

    <!-- Navigation -->
    <nav>
        <div class="logo">Portfolio</div>
        <ul>
            <li><a href="#about">About</a></li>
            <li><a href="#details">Details</a></li>
            <li><a href="#skills">Skills</a></li>
            <li><a href="#contact">Contact</a></li>
        </ul>
    </nav>

    <!-- Hero -->
    <section class="hero">
        <div class="hero-text">
            <h1>Nur Arisa Zuyyin</h1>
            <h2>Future Pharmacist & Student</h2>
            <p>
                Welcome to my personal portfolio website. I am a student from
                SMK Seri Duyong who is passionate about learning and achieving
                my dream of becoming a Pharmacist.
            </p>
            <a href="#about" class="btn">Explore More</a>
        </div>

        <div class="hero-image">
            <div class="profile-placeholder">
                <i class="fa-solid fa-user"></i>
            </div>
        </div>
    </section>

    <!-- About -->
    <section id="about">
        <h2 class="section-title">About Me</h2>

        <div class="contact-box">
            <p style="font-size:18px;">
                I am Nur Arisa Zuyyin, a student from SMK Seri Duyong.
                I enjoy reading books and learning new things.
                My favourite subject is Science, and my dream career is to become a Pharmacist.
                I like broccoli and always strive to improve myself academically and personally.
            </p>
        </div>
    </section>

    <!-- Details -->
    <section id="details">
        <h2 class="section-title">Student Profile</h2>

        <div class="cards">

            <div class="card">
                <i class="fa-solid fa-school"></i>
                <h3>School</h3>
                <p>SMK Seri Duyong</p>
            </div>

            <div class="card">
                <i class="fa-solid fa-briefcase-medical"></i>
                <h3>Dream Career</h3>
                <p>Pharmacist</p>
            </div>

            <div class="card">
                <i class="fa-solid fa-book-open"></i>
                <h3>Hobby</h3>
                <p>Read Books</p>
            </div>

            <div class="card">
                <i class="fa-solid fa-flask"></i>
                <h3>Favourite Subject</h3>
                <p>Science</p>
            </div>

        </div>
    </section>

    <!-- Skills -->
    <section id="skills">
        <h2 class="section-title">Skills & Interests</h2>

        <div class="cards">

            <div class="card">
                <i class="fa-solid fa-volleyball"></i>
                <h3>Sports</h3>
                <p>I enjoy playing volleyball and working as part of a team.</p>
            </div>

            <div class="card">
                <i class="fa-solid fa-book"></i>
                <h3>Reading</h3>
                <p>I enjoy reading books to gain knowledge and improve my understanding.</p>
            </div>

            <div class="card">
                <i class="fa-solid fa-lightbulb"></i>
                <h3>Learning</h3>
                <p>I am always eager to learn new skills and improve myself.</p>
            </div>

        </div>
    </section>

    <!-- Contact -->
    <section id="contact">
        <h2 class="section-title">Contact Me</h2>

        <div class="contact-box">
            <h3><i class="fa-solid fa-phone"></i>017-208-5579</h3>
            <br>
            <p>Feel free to contact me for educational or school-related opportunities.</p>
        </div>
    </section>

    <footer>
        © 2026 Nur Arisa Zuyyin | Personal Portfolio
    </footer>

</body>
</html>